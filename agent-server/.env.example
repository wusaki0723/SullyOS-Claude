PORT=8787
HOST=127.0.0.1

ANTHROPIC_API_KEY=your-anthropic-api-key

SULLY_AGENT_CLIENT_TOKEN=change-me
SULLY_AGENT_DATA_DIR=.data

SULLY_AGENT_DEFAULT_MODEL=sonnet
SULLY_AGENT_MAX_TURNS=6

SULLY_AGENT_CORS_ORIGIN=http://localhost:5173

# Optional but required for real background notifications.
# Generate with: npx web-push generate-vapid-keys
SULLY_AGENT_VAPID_PUBLIC_KEY=
SULLY_AGENT_VAPID_PRIVATE_KEY=
SULLY_AGENT_VAPID_SUBJECT=mailto:sully-agent@example.local

# Initial release keeps built-in high-risk tools closed.
SULLY_AGENT_ENABLE_BUILTIN_TOOLS=false
SULLY_AGENT_ENABLE_BASH=false
SULLY_AGENT_ENABLE_FILE_EDIT=false
SULLY_AGENT_ENABLE_WEB_SEARCH=false
